# Fingerprint² Environment Configuration
# Copy this to .env and fill in your API keys

# OpenRouter API Key (for multi-provider access)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Direct provider API keys (optional, OpenRouter can proxy these)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_API_KEY=your-google-api-key

# Database and storage paths (defaults are fine for development)
DATABASE_PATH=./data/fingerprints.db
RESULTS_PATH=./results
FHIBE_PATH=./fhibe_images

# Server configuration
HOST=0.0.0.0
PORT=8000
